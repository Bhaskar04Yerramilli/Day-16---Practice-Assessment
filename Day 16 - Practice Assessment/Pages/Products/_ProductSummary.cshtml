@model RazorProductsApp.Models.Product

<div style="border:1px solid black; padding:10px; margin:10px;">

    <h3>@Model.Name</h3>

    <p>@Model.Description</p>

    <h4>Categories</h4>

    <ul>
        @foreach (var category in Model.Categories)
        {
            <li>
                @category.CategoryID - @category.Name
            </li>
        }
    </ul>

</div>